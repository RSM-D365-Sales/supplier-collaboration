PORT=3001

# URL of the frontend used for CORS and vendor portal links (no trailing slash).
# Local dev:   http://localhost:5175
# Production:  https://rsmd365.com/supplier-collaboration
FRONTEND_URL=http://localhost:5175

# --- D365 Finance & Supply Chain Connection ---
# Leave blank to run in mock/demo mode (USE_MOCK_DATA=true)
D365_BASE_URL=https://your-org.operations.dynamics.com
D365_TENANT_ID=your-azure-ad-tenant-id
D365_CLIENT_ID=your-app-registration-client-id
D365_CLIENT_SECRET=your-app-registration-client-secret

# --- Token Configuration ---
TOKEN_EXPIRY_DAYS=30

# --- Demo Mode ---
# Set to true to use built-in mock data instead of live D365
USE_MOCK_DATA=true

# --- Email / SMTP ---
# Leave SMTP_HOST blank to use Ethereal (test only – preview URL logged to console).
# In production set these in Azure App Service → Configuration → App Settings.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
