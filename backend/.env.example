PORT=3001

# Public URL of the SPA — used in vendor invitation emails to build the portal link.
# Single-Web-App deployment: include the Vite base path (default '/supplier-collaboration').
# Local dev:   http://localhost:5175
# Production:  https://www.rsmd365.com/supplier-collaboration
FRONTEND_URL=http://localhost:5175

# Path under which the built SPA is mounted by the Express server. Must match
# Vite's `base` in frontend/vite.config.ts. Default: /supplier-collaboration
FRONTEND_BASE_PATH=/supplier-collaboration

# --- iframe / D365 Workspace Embedding ---
# Space-separated list of origins allowed to embed the portal in an iframe.
# Set this to your D365 F&O tenant URL so the portal loads in a D365 workspace tile.
# Example: https://cd1.operations.dynamics.com
D365_FRAME_ANCESTORS=https://your-tenant.operations.dynamics.com

# --- D365 Finance & Supply Chain Connection ---
# Leave blank to run in mock/demo mode (USE_MOCK_DATA=true)
D365_BASE_URL=https://your-org.operations.dynamics.com
D365_TENANT_ID=your-azure-ad-tenant-id
D365_CLIENT_ID=your-app-registration-client-id
D365_CLIENT_SECRET=your-app-registration-client-secret

# --- Token Configuration ---
TOKEN_EXPIRY_DAYS=30

# --- Demo Mode ---
# Set to true to use built-in mock data instead of live D365
USE_MOCK_DATA=true

# --- Email / SMTP ---
# Leave SMTP_HOST blank to use Ethereal (test only – preview URL logged to console).
# In production set these in Azure App Service → Configuration → App Settings.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
